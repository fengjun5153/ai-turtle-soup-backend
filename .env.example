# Server（云平台一般会注入 PORT，勿写死）
PORT=3001
# 公网必须监听 0.0.0.0（默认已是 0.0.0.0，一般不用改）
HOST=0.0.0.0
# 前端完整地址，多个用英文逗号分隔，须与浏览器地址栏 Origin 完全一致（含 https）
# 例：CLIENT_ORIGIN=https://your-app.vercel.app,http://localhost:5173
CLIENT_ORIGIN=http://localhost:5173

# DeepSeek API（必填，在平台「环境变量」里配置，不要提交到 Git）
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
